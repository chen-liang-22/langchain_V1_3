  - tenant_id: VARCHAR(20) [注释: 租户编号]
  - training_name: VARCHAR(128) [注释: 任务名称]
  - dept_id: BIGINT [注释: 所属部门ID（用于管理端数据权限控制）]
  - instance_id: VARCHAR(64) [注释: 客户画像实例ID]
  - training_type: TINYINT [注释: 训练类型 1管理员指定训练 2员工自建训练]
  - student_tags: JSON [注释: 学员画像标签JSON数组]
  - customer_tags: JSON [注释: 客户画像标签JSON数组]
  - question_count: INTEGER [注释: 问答次数，-1表示不限]
  - valid_days: INTEGER [注释: 任务周期（天数），-1表示不限]
  - task_count: INTEGER [注释: 任务次数，-1表示不限]
  - completion_standard: TINYINT [注释: 完成训练标准 1达到问答总数 2达到目标综合 3达到问答总数/目标综合]
  - info_config_type: TINYINT [注释: 训练信息配置 1基于允许使用分析]
  - is_shared: TINYINT [注释: 是否共享（0否 1是）]
  - allow_expired_training: TINYINT [注释: 是否允许超期继续训练 0=不允许 1=允许]
  - status: TINYINT [注释: 状态 0草稿 1启用 2停用]
  - publish_time: DATETIME [注释: 发布时间]
  - del_flag: CHAR(1) [注释: 删除标志 0未删除 1已删除]
  - create_dept: BIGINT [注释: 创建部门]
  - create_by: BIGINT [注释: 创建者]
  - create_time: DATETIME [注释: 创建时间]
  - update_by: BIGINT [注释: 更新者]
  - update_time: DATETIME [注释: 更新时间]
  - customer_instance_ai: TEXT [注释: 客户实例AI版]
  - customer_instance_manual: TEXT [注释: 客户实例人工修改版]
  - min_stage_code: VARCHAR(32) [注释: 最小可见阶段编码，对应字典 employee_stage.dict_value]
  - stage: VARCHAR(255) [注释: 当前阶段]
索引信息:
  - idx_training_dept: ['dept_id', 'create_time'] (普通索引)
  - idx_training_name: ['training_name'] (普通索引)
  - idx_training_status: ['status', 'create_time'] (普通索引)
  - idx_training_tenant: ['tenant_id', 'del_flag'] (普通索引)
  - idx_training_type: ['training_type', 'status'] (普通索引)

