表名: ai_simulation_training_session
列信息:
  - id: BIGINT (主键) [注释: 主键ID]
  - session_no: VARCHAR(32) COLLATE "utf8mb4_general_ci" [注释: 会话编号（格式：SES + yyyyMMdd + 001-999）]
  - training_id: BIGINT [注释: 训练ID]
  - training_user_id: BIGINT [注释: 训练成员ID（所有训练会话都必须有）]
  - user_id: BIGINT [注释: 用户ID]
  - training_type: TINYINT [注释: 训练类型（1:管理员指定训练 2:员工自建训练）]
  - max_round_count: INTEGER [注释: 最大问答轮数]
  - max_message_count: INTEGER [注释: 最大消息条数（用户发送）]
  - current_round: INTEGER [注释: 当前轮次]
  - user_message_count: INTEGER [注释: 用户已发送消息数]
  - resume_count: INTEGER [注释: 恢复训练次数]
  - lock_frontend_key: VARCHAR(64) COLLATE "utf8mb4_general_ci" [注释: 当前持锁标签页标识]
  - session_status: TINYINT [注释: 会话状态（0:未开始 1:进行中 2:未完成 3:已中断 4:已完成 5:已重置）]
  - start_time: DATETIME [注释: 开始时间]
  - end_time: DATETIME [注释: 结束时间]
  - last_active_time: DATETIME [注释: 最后活跃时间（心跳/发消息时更新）]
  - is_abnormal_close: TINYINT [注释: 是否异常关闭（0:否 1:是）]
  - abnormal_reason: VARCHAR(255) COLLATE "utf8mb4_general_ci" [注释: 异常中断原因]
  - complete_status: TINYINT [注释: 是否完成 0否 1是]
  - complete_remark: VARCHAR(255) COLLATE "utf8mb4_general_ci" [注释: 完成原因]
  - create_dept: BIGINT [注释: 创建部门]
  - create_by: BIGINT [注释: 创建人]
  - create_time: DATETIME [注释: 创建时间]
  - update_by: BIGINT [注释: 修改人]
  - update_time: DATETIME [注释: 修改时间]
  - del_flag: CHAR(1) COLLATE "utf8mb4_general_ci" [注释: 删除标志（0:未删除 1:已删除）]
  - tenant_id: VARCHAR(20) COLLATE "utf8mb4_general_ci" [注释: 租户编号]
索引信息:
  - idx_ai_simulation_training_session_tenant: ['tenant_id', 'del_flag'] (普通索引)
  - idx_ai_simulation_training_session_training_user_status: ['training_id', 'user_id', 'session_status'] (普通索引)
  - idx_ai_simulation_training_session_user_status_active: ['user_id', 'session_status', 'last_active_time'] (普通索引)

